<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Monte Seu Robô!</title>
<style>
@import url('https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700;900&family=Share+Tech+Mono&display=swap');

:root {
  --bg: #0a0e1a;
  --panel: #111827;
  --border: #1e3a5f;
  --cyan: #00d4ff;
  --green: #39ff14;
  --yellow: #ffd700;
  --red: #ff4757;
  --white: #e8f4fd;
  --muted: #4a6fa5;
}

* { box-sizing: border-box; margin: 0; padding: 0; }

body {
  background: var(--bg);
  color: var(--white);
  font-family: 'Share Tech Mono', monospace;
  min-height: 100vh;
  overflow-x: hidden;
}

/* Scanline overlay */
body::before {
  content: '';
  position: fixed; inset: 0;
  background: repeating-linear-gradient(0deg, transparent, transparent 2px, rgba(0,212,255,0.015) 2px, rgba(0,212,255,0.015) 4px);
  pointer-events: none;
  z-index: 999;
}

header {
  text-align: center;
  padding: 2rem 1rem 1rem;
  border-bottom: 1px solid var(--border);
}

header h1 {
  font-family: 'Orbitron', sans-serif;
  font-size: clamp(1.6rem, 5vw, 2.8rem);
  font-weight: 900;
  color: var(--cyan);
  text-shadow: 0 0 20px rgba(0,212,255,0.6), 0 0 40px rgba(0,212,255,0.3);
  letter-spacing: 0.08em;
}

header p {
  color: var(--muted);
  margin-top: 0.4rem;
  font-size: 0.85rem;
  letter-spacing: 0.1em;
  text-transform: uppercase;
}

/* Progress bar */
.progress-bar {
  width: 100%;
  height: 4px;
  background: var(--border);
  margin-top: 1rem;
}
.progress-fill {
  height: 100%;
  width: 0%;
  background: linear-gradient(90deg, var(--cyan), var(--green));
  transition: width 0.5s cubic-bezier(0.4, 0, 0.2, 1);
  box-shadow: 0 0 8px var(--cyan);
}

main {
  max-width: 1100px;
  margin: 0 auto;
  padding: 2rem 1rem;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 1.5rem;
}

@media (max-width: 720px) {
  main { grid-template-columns: 1fr; }
}

/* ROBOT PREVIEW */
.robot-stage {
  background: var(--panel);
  border: 1px solid var(--border);
  border-radius: 4px;
  padding: 1.5rem;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0.5rem;
  position: relative;
  overflow: hidden;
  align-self: start;
  position: sticky;
  top: 1.5rem;
}

.robot-stage::before {
  content: 'VISUALIZAÇÃO';
  position: absolute;
  top: 0.6rem; left: 1rem;
  font-size: 0.65rem;
  color: var(--muted);
  letter-spacing: 0.15em;
}

.robot-display {
  width: 220px;
  height: 300px;
  position: relative;
  margin-top: 1.5rem;
}

.robot-part {
  position: absolute;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2px dashed rgba(30, 58, 95, 0.3);
  border-radius: 4px;
  transition: all 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  font-size: 2.5rem;
  opacity: 0.1;
  transform: scale(0.8);
  background: rgba(0,0,0,0.2);
}

.robot-part.placed {
  opacity: 1;
  transform: scale(1);
  border-style: solid;
  border-color: var(--cyan);
  box-shadow: 0 0 12px rgba(0,212,255,0.3);
  animation: partGlow 2s ease-in-out infinite;
  background: rgba(0, 212, 255, 0.05);
}

@keyframes partGlow {
  0%, 100% { box-shadow: 0 0 8px rgba(0,212,255,0.2); }
  50% { box-shadow: 0 0 20px rgba(0,212,255,0.5); border-color: var(--green); }
}

/* Robot part positions */
.p-head { top: 0px; left: 60px; width: 100px; height: 80px; }
.p-torso { top: 88px; left: 40px; width: 140px; height: 100px; font-size: 3rem; }
.p-left-arm { top: 92px; left: 0px; width: 36px; height: 90px; }
.p-right-arm { top: 92px; right: 0px; width: 36px; height: 90px; }
.p-left-leg { top: 196px; left: 44px; width: 50px; height: 100px; }
.p-right-leg { top: 196px; right: 44px; width: 50px; height: 100px; }

.status-log {
  width: 100%;
  background: rgba(0,0,0,0.4);
  border: 1px solid var(--border);
  border-radius: 2px;
  padding: 0.75rem;
  min-height: 60px;
  font-size: 0.78rem;
  color: var(--green);
  letter-spacing: 0.05em;
  margin-top: 0.5rem;
}

.status-log span { color: var(--muted); }

/* ASSEMBLY PANEL */
.assembly-panel {
  display: flex;
  flex-direction: column;
  gap: 1rem;
}

.step-card {
  background: var(--panel);
  border: 1px solid var(--border);
  border-radius: 4px;
  padding: 1.2rem;
  transition: border-color 0.3s, background 0.3s;
  position: relative;
  overflow: hidden;
}

.step-card:not(.done):not(.locked) {
  border-color: var(--cyan);
  background: rgba(0,212,255,0.02);
}

.step-card.active {
  border-color: var(--yellow);
  background: rgba(255,215,0,0.04);
  box-shadow: 0 0 15px rgba(255,215,0,0.05);
}

.step-card.done {
  border-color: var(--green);
  background: rgba(57,255,20,0.02);
  opacity: 0.8;
}

.step-card.locked {
  opacity: 0.3;
}

.step-card::before {
  content: '';
  position: absolute;
  left: 0; top: 0; bottom: 0;
  width: 3px;
  background: var(--border);
  transition: background 0.2s;
}
.step-card.active::before { background: var(--yellow); box-shadow: 0 0 8px var(--yellow); }
.step-card.done::before { background: var(--green); box-shadow: 0 0 8px var(--green); }

.step-header {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  margin-bottom: 0.5rem;
}

.step-num {
  font-family: 'Orbitron', sans-serif;
  font-size: 0.65rem;
  color: var(--muted);
  letter-spacing: 0.15em;
  white-space: nowrap;
}

.step-title {
  font-family: 'Orbitron', sans-serif;
  font-size: 0.9rem;
  font-weight: 700;
  color: var(--white);
  flex: 1;
}

.step-icon { font-size: 1.4rem; }

.step-desc {
  font-size: 0.8rem;
  color: #7a99bb;
  line-height: 1.5;
  margin-bottom: 0.75rem;
}

.step-task {
  background: rgba(0,0,0,0.3);
  border-left: 2px solid var(--yellow);
  padding: 0.5rem 0.75rem;
  font-size: 0.78rem;
  color: var(--yellow);
  letter-spacing: 0.03em;
  margin-bottom: 0.75rem;
}

.step-task strong { display: block; color: #fff; margin-bottom: 0.2rem; font-size: 0.7rem; letter-spacing: 0.1em; }

.btn-install {
  background: transparent;
  border: 1px solid var(--cyan);
  color: var(--cyan);
  font-family: 'Share Tech Mono', monospace;
  font-size: 0.8rem;
  padding: 0.5rem 1.2rem;
  cursor: pointer;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  transition: all 0.2s;
  display: flex;
  align-items: center;
  gap: 0.5rem;
}

.btn-install:hover {
  background: var(--cyan);
  color: var(--bg);
  box-shadow: 0 0 10px rgba(0,212,255,0.5);
}

/* CELEBRATION */
.celebration {
  display: none;
  position: fixed;
  inset: 0;
  background: rgba(0,10,20,0.95);
  z-index: 1000;
  align-items: center;
  justify-content: center;
  flex-direction: column;
  text-align: center;
  padding: 2rem;
  gap: 1.5rem;
}

.celebration.show { display: flex; }

.celebration h2 {
  font-family: 'Orbitron', sans-serif;
  font-size: clamp(1.8rem, 6vw, 3rem);
  font-weight: 900;
  color: var(--green);
  text-shadow: 0 0 30px rgba(57,255,20,0.7);
  animation: pulse 1s ease-in-out infinite;
}

.celebration p {
  font-size: 1rem;
  color: var(--white);
  max-width: 460px;
  line-height: 1.6;
}

.robot-complete { font-size: 6rem; animation: bounce 0.6s ease-in-out infinite alternate; }

@keyframes pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.7; }
}

@keyframes bounce {
  from { transform: translateY(0); }
  to { transform: translateY(-15px); }
}

.btn-restart {
  background: var(--green);
  color: var(--bg);
  border: none;
  font-family: 'Orbitron', sans-serif;
  font-size: 0.85rem;
  font-weight: 700;
  padding: 0.75rem 2rem;
  cursor: pointer;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  transition: transform 0.2s, box-shadow 0.2s;
}

.btn-restart:hover {
  transform: scale(1.05);
  box-shadow: 0 0 15px var(--green);
}

.counter {
  text-align: center;
  padding: 0.75rem;
  font-family: 'Orbitron', sans-serif;
  font-size: 0.75rem;
  letter-spacing: 0.15em;
  color: var(--muted);
  grid-column: 1 / -1;
}

.counter span { color: var(--cyan); font-size: 1rem; font-weight: 700; }

/* particle effect */
.sparks { position: fixed; inset: 0; pointer-events: none; z-index: 998; }
</style>
</head>
<body>

<header>
  <h1>⚙ MONTE SEU ROBÔ ⚙</h1>
  <p>Dinâmica de montagem em equipe — complete cada etapa para ativar o robô</p>
  <div class="progress-bar"><div class="progress-fill" id="progressFill"></div></div>
</header>

<main>
  <div class="robot-stage">
    <div class="robot-display" id="robotDisplay">
      <div class="robot-part p-head" id="rp-head">🤖</div>
      <div class="robot-part p-torso" id="rp-torso">🦾</div>
      <div class="robot-part p-left-arm" id="rp-left-arm">⚡</div>
      <div class="robot-part p-right-arm" id="rp-right-arm">⚡</div>
      <div class="robot-part p-left-leg" id="rp-left-leg">🦿</div>
      <div class="robot-part p-right-leg" id="rp-right-leg">🦿</div>
    </div>
    <div class="status-log" id="statusLog">
      <span>// aguardando início da montagem...</span>
    </div>
  </div>

  <div class="assembly-panel" id="assemblyPanel">
    </div>
  
  <div class="counter" id="counter">
    PEÇAS INSTALADAS: <span id="doneCount">0</span> / 6
  </div>
</main>

<div class="celebration" id="celebration">
  <div class="robot-complete">🤖</div>
  <h2>ROBÔ ATIVADO!</h2>
  <p>Parabéns! Sua equipe concluiu a montagem com sucesso. O robô está 100% operacional e integrado!</p>
  <button class="btn-restart" onclick="restart()">↺ MONTAR NOVAMENTE</button>
</div>
<canvas class="sparks" id="sparks"></canvas>

<script>
const steps = [
  {
    id: 'head',
    partId: 'rp-head',
    num: '01',
    title: 'INSTALAR CABEÇA',
    icon: '🤖',
    desc: 'O núcleo de processamento central. Contém os sensores visuais, o microfone e a unidade de inteligência artificial.',
    task: 'A equipe deve decidir: quais serão os 3 principais valores que guiam as decisões deste robô? Cada pessoa sugere um e juntos escolhem os melhores.',
    log: '> Cabeça instalada. Sistemas de IA inicializados.',
  },
  {
    id: 'torso',
    partId: 'rp-torso',
    num: '02',
    title: 'FIXAR TRONCO',
    icon: '🔧',
    desc: 'O chassi principal. Abriga o gerador de energia, os circuitos de controle e conecta todas as demais peças.',
    task: 'Desafio: cada membro da equipe tem 30 segundos para explicar qual é a "energia" que mantém o grupo funcionando. O facilitador anota as respostas.',
    log: '> Tronco fixado. Gerador de energia operacional.',
  },
  {
    id: 'left-arm',
    partId: 'rp-left-arm',
    num: '03',
    title: 'BRAÇO ESQUERDO',
    icon: '🦾',
    desc: 'O braço de criação. Especializado em construir, escrever e expressar ideias com precisão.',
    task: 'A equipe tem 2 minutos para criar um slogan ou nome criativo para o robô. Todas as sugestões valem — votem no favorito!',
    log: '> Braço esquerdo conectado. Ferramentas criativas ativas.',
  },
  {
    id: 'right-arm',
    partId: 'rp-right-arm',
    num: '04',
    title: 'BRAÇO DIREITO',
    icon: '🦾',
    desc: 'O braço analítico. Especializado em calcular, analisar dados e tomar decisões lógicas.',
    task: 'Raciocínio em equipe: se o robô precisasse resolver um problema do grupo agora, qual seria? Como ele usaria lógica para solucionar?',
    log: '> Braço direito conectado. Módulo analítico calibrado.',
  },
  {
    id: 'left-leg',
    partId: 'rp-left-leg',
    num: '05',
    title: 'PERNA ESQUERDA',
    icon: '🦿',
    desc: 'O suporte de exploração. Permite que o robô avance para novos territórios com estabilidade.',
    task: 'Cada pessoa compartilha: qual habilidade nova você gostaria de explorar este ano? O robô absorve esse conhecimento coletivo!',
    log: '> Perna esquerda instalada. Módulo de exploração ativo.',
  },
  {
    id: 'right-leg',
    partId: 'rp-right-leg',
    num: '06',
    title: 'PERNA DIREITA',
    icon: '🦿',
    desc: 'O suporte de consolidação. Garante estabilidade e permite que o robô sustente suas conquistas.',
    task: 'Missão final: a equipe define UMA meta coletiva para o próximo mês. Isso é o combustível para o robô decolar!',
    log: '> Perna direita instalada. Estabilidade estrutural confirmada.',
  },
];

let current = 0;
let done = new Set();

function renderSteps() {
  const panel = document.getElementById('assemblyPanel');
  panel.innerHTML = '';

  steps.forEach((s, i) => {
    const isDone = done.has(s.id);
    const isActive = i === current;
    const isLocked = i > current;

    const card = document.createElement('div');
    card.id = `card-${s.id}`;
    card.className = `step-card ${isDone ? 'done' : isActive ? 'active' : isLocked ? 'locked' : ''}`;
    
    let footerContent = '';
    if (isActive) {
      footerContent = `
        <div class="step-task">
          <strong>// TAREFA DA EQUIPE</strong>
          ${s.task}
        </div>
        <button class="btn-install" onclick="installPart('${s.id}', ${i})">
          ⚡ INSTALAR PEÇA
        </button>
      `;
    } else if (isDone) {
      footerContent = `<div style="font-size:0.75rem;color:var(--green);letter-spacing:0.1em;margin-top:0.5rem;">✓ CONCLUÍDO</div>`;
    }

    card.innerHTML = `
      <div class="step-header">
        <span class="step-num">ETAPA ${s.num}</span>
        <span class="step-icon">${isDone ? '✅' : s.icon}</span>
        <span class="step-title">${s.title}</span>
      </div>
      <div class="step-desc">${s.desc}</div>
      ${footerContent}
    `;
    panel.appendChild(card);
  });
}

function installPart(partId, index) {
  if (done.has(partId)) return;

  done.add(partId);

  const step = steps[index];
  const el = document.getElementById(step.partId);
  if (el) el.classList.add('placed');

  // Ajuste do ícone interno do tronco ao fixar
  if (partId === 'torso') {
    el.textContent = '⚙️';
  }

  // Log de status
  const log = document.getElementById('statusLog');
  log.innerHTML = `${step.log}<br><span>// peças instaladas: ${done.size}/6</span>`;

  // Barra de progresso e contador
  document.getElementById('progressFill').style.width = `${(done.size / 6) * 100}%`;
  document.getElementById('doneCount').textContent = done.size;

  sparkBurst();

  // Avança o estado atual
  current = index + 1;

  renderSteps();

  // Scroll suave para o próximo item ativo
  if (current < steps.length) {
    setTimeout(() => {
      const nextCard = document.getElementById(`card-${steps[current].id}`);
      if (nextCard) nextCard.scrollIntoView({ behavior: 'smooth', block: 'center' });
    }, 150);
  }

  // Checa vitória
  if (done.size === 6) {
    setTimeout(() => {
      document.getElementById('celebration').classList.add('show');
      launchParticles();
    }, 800);
  }
}

function restart() {
  done.clear();
  current = 0;
  document.getElementById('celebration').classList.remove('show');
  document.getElementById('progressFill').style.width = '0%';
  document.getElementById('doneCount').textContent = '0';
  document.getElementById('statusLog').innerHTML = '<span>// aguardando início da montagem...</span>';
  
  steps.forEach(s => {
    const el = document.getElementById(s.partId);
    if (el) { 
      el.classList.remove('placed'); 
      // Reseta os ícones originais do display do robô
      if(s.id === 'head') el.textContent = '🤖';
      if(s.id === 'torso') el.textContent = '🦾';
      if(s.id === 'left-arm' || s.id === 'right-arm') el.textContent = '⚡';
      if(s.id === 'left-leg' || s.id === 'right-leg') el.textContent = '🦿';
    }
  });
  renderSteps();
  window.scrollTo({ top: 0, behavior: 'smooth' });
}

// --- CANVAS PARTICLES ---
const canvas = document.getElementById('sparks');
const ctx = canvas.getContext('2d');
let particles = [];

function resize() {
  canvas.width = window.innerWidth;
  canvas.height = window.innerHeight;
}
window.addEventListener('resize', resize);
resize();

function sparkBurst() {
  const cx = window.innerWidth / 2;
  const cy = window.innerHeight / 2;
  for (let i = 0; i < 30; i++) {
    const angle = Math.random() * Math.PI * 2;
    const speed = 2 + Math.random() * 5;
    particles.push({
      x: cx, y: cy,
      vx: Math.cos(angle) * speed,
      vy: Math.sin(angle) * speed,
      life: 1,
      color: ['#00d4ff', '#39ff14', '#ffd700'][Math.floor(Math.random() * 3)],
      size: 2 + Math.random() * 3,
    });
  }
}

function launchParticles() {
  for (let i = 0; i < 120; i++) {
    const angle = Math.random() * Math.PI * 2;
    const speed = 3 + Math.random() * 8;
    particles.push({
      x: Math.random() * window.innerWidth,
      y: Math.random() * window.innerHeight * 0.5,
      vx: Math.cos(angle) * speed,
      vy: Math.sin(angle) * speed * 2, // Corrigido o operador ausente
      life: 1,
      color: ['#00d4ff', '#39ff14', '#ffd700', '#ff4757'][Math.floor(Math.random() * 4)],
      size: 3 + Math.random() * 4,
    });
  }
}

function animateParticles() {
  ctx.clearRect(0, 0, canvas.width, canvas.height);
  particles = particles.filter(p => p.life > 0.01);
  particles.forEach(p => {
    p.x += p.vx;
    p.y += p.vy;
    p.vy += 0.12;
    p.life *= 0.94;
    ctx.globalAlpha = p.life;
    ctx.fillStyle = p.color;
    ctx.beginPath();
    ctx.arc(p.x, p.y, p.size, 0, Math.PI * 2);
    ctx.fill();
  });
  ctx.globalAlpha = 1;
  requestAnimationFrame(animateParticles);
}

animateParticles();
renderSteps();
</script>
</body>
</html>
